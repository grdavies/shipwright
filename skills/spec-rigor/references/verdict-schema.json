{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "spec-rigor verdict",
  "type": "object",
  "required": ["verdict", "artifact", "findings"],
  "properties": {
    "verdict": { "enum": ["pass", "warn", "fail"] },
    "artifact": { "enum": ["prd", "tasks"] },
    "tier": { "enum": ["full", "standard"] },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["gate", "severity", "message"],
        "properties": {
          "gate": { "enum": ["clarify", "checklist", "analyze", "traceability"] },
          "severity": { "enum": ["error", "warn", "info"] },
          "message": { "type": "string" },
          "rid": { "type": "string" }
        }
      }
    }
  }
}
