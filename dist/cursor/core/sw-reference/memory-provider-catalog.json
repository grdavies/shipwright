{
  "version": 1,
  "description": "Authoritative memory provider capability catalog (PRD 071 R2). Emitted to core/sw-reference via build-chain.",
  "providers": {
    "recallium": {
      "adapterDoc": "core/providers/recallium.md",
      "rulesScript": "providers/recallium-rules.py",
      "capabilities": {
        "typedMemories": true,
        "filePathSearch": true,
        "categoryFilter": true,
        "recencyControl": true,
        "rulesAtStartup": true,
        "tasks": true,
        "export": false,
        "import": false,
        "softDelete": true,
        "semanticSearch": true
      },
      "hookTransport": {
        "agentSession": "mcp",
        "ruleFetch": "out-of-band-script",
        "notes": "Agent-session ops via Recallium MCP tools; guardrail hooks invoke providers/recallium-rules.py (non-MCP, budgeted rule-fetch).",
        "restFetchPolicy": {
          "allowedHosts": [
            "localhost",
            "127.0.0.1",
            "::1"
          ],
          "allowLoopback": true,
          "allowPrivate": false,
          "allowLinkLocal": false,
          "allowMetadata": false
        }
      },
      "interchange": {
        "jsonl": "synthesized",
        "okf": "synthesized"
      },
      "sourceOfTruthClass": "memory-authoritative",
      "credentials": {
        "location": "env-only",
        "notes": "REST/MCP credentials from environment or secret store only \u2014 never catalog, config bodies, or memory content."
      }
    },
    "in-repo": {
      "adapterDoc": "core/providers/in-repo.md",
      "rulesScript": "providers/in-repo-rules.py",
      "capabilities": {
        "typedMemories": true,
        "filePathSearch": true,
        "categoryFilter": true,
        "recencyControl": true,
        "rulesAtStartup": true,
        "tasks": false,
        "export": true,
        "import": true,
        "softDelete": true,
        "semanticSearch": false
      },
      "hookTransport": {
        "agentSession": "filesystem",
        "ruleFetch": "out-of-band-script",
        "notes": "Agent-session ops via committed markdown store and in-repo-memory-search.py (compiled truth + append-only timeline, atomic update-truth); guardrail hooks read providers/in-repo-rules.py against .cursor/sw-memory/rules/. Not a Brain.md provider — no brain/ SoT directory."
      },
      "interchange": {
        "jsonl": "native",
        "okf": "native"
      },
      "sourceOfTruthClass": "repo-authoritative",
      "credentials": {
        "location": "none",
        "notes": "Offline-first provider \u2014 no remote credentials."
      }
    },
    "mempalace": {
      "adapterDoc": "core/providers/mempalace.md",
      "rulesScript": "providers/mempalace-rules.py",
      "capabilities": {
        "typedMemories": true,
        "filePathSearch": false,
        "categoryFilter": true,
        "recencyControl": true,
        "rulesAtStartup": true,
        "tasks": false,
        "export": true,
        "import": true,
        "softDelete": false,
        "semanticSearch": true
      },
      "hookTransport": {
        "agentSession": "mcp",
        "ruleFetch": "out-of-band-script",
        "notes": "Agent-session ops via MemPalace MCP tools; guardrail hooks invoke providers/mempalace-rules.py (fixed-argv local palacePath, non-MCP)."
      },
      "interchange": {
        "jsonl": "synthesized",
        "okf": "synthesized"
      },
      "sourceOfTruthClass": "memory-authoritative",
      "credentials": {
        "location": "none",
        "notes": "Local-only palacePath \u2014 no remote credentials; never store palace contents in catalog or config secrets."
      }
    },
    "basic-memory": {
      "adapterDoc": "core/providers/basic-memory.md",
      "rulesScript": "providers/basic-memory-rules.py",
      "capabilities": {
        "typedMemories": true,
        "filePathSearch": false,
        "categoryFilter": true,
        "recencyControl": true,
        "rulesAtStartup": true,
        "tasks": false,
        "export": true,
        "import": true,
        "softDelete": false,
        "semanticSearch": true
      },
      "hookTransport": {
        "agentSession": "mcp",
        "ruleFetch": "out-of-band-script",
        "notes": "Dual-mode provider (memory.basicMemory.mode: local|cloud). Agent-session via basic-memory MCP; hooks via providers/basic-memory-rules.py (non-MCP). Mode is operator-selected \u2014 no silent local\u2194cloud fallback. Local: loopback MCP/HTTP only. Cloud: bearer token from env/secret-store (BASIC_MEMORY_API_KEY) against allowlisted cloud.basicmemory.com only. Rule-cache keys are mode-partitioned.",
        "restFetchPolicy": {
          "allowedHosts": [
            "localhost",
            "127.0.0.1",
            "::1",
            "cloud.basicmemory.com"
          ],
          "allowLoopback": true,
          "allowPrivate": false,
          "allowLinkLocal": false,
          "allowMetadata": false
        }
      },
      "interchange": {
        "jsonl": "synthesized",
        "okf": "synthesized"
      },
      "sourceOfTruthClass": "memory-authoritative",
      "credentials": {
        "location": "env-only",
        "notes": "Cloud mode: BASIC_MEMORY_API_KEY (bmc_\u2026) from environment or secret store only \u2014 never catalog, config bodies, or memory content. Local mode needs no remote token."
      }
    },
    "obsidian": {
      "adapterDoc": "core/providers/obsidian.md",
      "rulesScript": "providers/obsidian-rules.py",
      "capabilities": {
        "typedMemories": true,
        "filePathSearch": true,
        "categoryFilter": true,
        "recencyControl": true,
        "rulesAtStartup": true,
        "tasks": false,
        "export": true,
        "import": true,
        "softDelete": false,
        "semanticSearch": false
      },
      "hookTransport": {
        "agentSession": "mcp",
        "ruleFetch": "out-of-band-script",
        "notes": "Agent-session via Obsidian Local REST API built-in MCP on loopback (default http://127.0.0.1:27123). Hooks use providers/obsidian-rules.py (vaultPath filesystem and/or loopback REST, non-MCP). Obsidian + Local REST API plugin must be running for agent ops. Bearer token from env/secret-store (OBSIDIAN_API_KEY). No silent fallback to another provider.",
        "restFetchPolicy": {
          "allowedHosts": [
            "localhost",
            "127.0.0.1",
            "::1"
          ],
          "allowLoopback": true,
          "allowPrivate": false,
          "allowLinkLocal": false,
          "allowMetadata": false
        }
      },
      "interchange": {
        "jsonl": "synthesized",
        "okf": "synthesized"
      },
      "sourceOfTruthClass": "memory-authoritative",
      "credentials": {
        "location": "env-only",
        "notes": "OBSIDIAN_API_KEY (Local REST API bearer) from environment or secret store only \u2014 never catalog, config bodies, or memory content."
      },
      "planningLineage": {
        "prd": "076-prd-obsidian-memory-provider",
        "dependsOn": [
          "071-prd-pluggable-memory-adapter-framework"
        ],
        "doesNotSupersede": [
          "074-prd-mempalace-memory-provider",
          "075-prd-basic-memory-provider",
          "010"
        ],
        "portfolioItem": "C",
        "portfolioDecision": "planning#491"
      }
    }
  }
}
