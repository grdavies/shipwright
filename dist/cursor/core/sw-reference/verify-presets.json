{
  "version": 1,
  "presets": {
    "node": {
      "lint": "npm run lint",
      "typecheck": "npm run typecheck",
      "test": "npm run test",
      "build": "npm run build"
    },
    "python": {
      "lint": "ruff check .",
      "typecheck": "mypy .",
      "test": "pytest",
      "build": "python -m build"
    },
    "go": {
      "lint": "golangci-lint run ./...",
      "test": "go test ./...",
      "build": "go build ./..."
    },
    "ansible": {
      "lint": "ansible-lint",
      "test": "ansible-playbook --syntax-check site.yml"
    },
    "make": {
      "lint": "make lint",
      "test": "make test",
      "build": "make build"
    },
    "ruby": {},
    "jvm": {}
  },
  "nodeAllowlistedKeys": ["lint", "test", "build", "typecheck"],
  "nodeKeyPattern": "^[a-zA-Z0-9_-]+$"
}
