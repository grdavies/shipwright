#!/usr/bin/env bash
set -euo pipefail
DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(git rev-parse --show-toplevel)"
GUARD="$DIR/../../scripts/planning_materialize.py"
if [[ -f "$GUARD" ]]; then
  export PYTHONPATH="$DIR/../../scripts:${PYTHONPATH:-}"
  python3 "$GUARD" --root "$ROOT" guard-staged --push
fi
SCAN="$DIR/../../scripts/secret-scan.sh"
[ -x "$SCAN" ] && "$SCAN" pre-push
