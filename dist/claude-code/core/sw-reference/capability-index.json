      "id": "provider.providers.code-review.specialists.adversarial",
      "kind": "provider",
      "sourcePath": "core/providers/code-review/specialists/adversarial.md",
      "executable": true,
      "capability": {
        "version": 1,
        "triggers": [
          {
            "type": "any_of",
            "selectionFamily": "code-review",
            "triggers": [
              {
                "type": "change_digest",
                "predicate": "executable_lines_gte",
                "threshold": 50
              },
              {
                "type": "change_digest",
                "predicate": "regex_in_added_lines",
                "patterns": [
                  "\\b(auth|payment|stripe|mutation|external.api|webhook)\\b"
                ]
              }
            ]
          }
        ],
        "metadata": {
          "specialistId": "adversarial",
          "selectionFamily": "code-review"
        }
