{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/grdavies/shipwright/core/sw-reference/phase-step-plan.schema.json",
  "title": "Shipwright phase step plan and wave-batching plan",
  "description": "Versioned validated plans for per-phase step execution and conductor wave batching (PRD 022 R5, R7).",
  "oneOf": [
    {"$ref": "#/definitions/phaseStepPlan"},
    {"$ref": "#/definitions/waveBatchingPlan"}
  ],
  "definitions": {
    "stepId": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
    "planPolicy": {"type": "string", "enum": ["canonical", "proposed"], "default": "canonical"},
    "versionStamp": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "phaseStepPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "tier", "phaseType", "steps", "planPolicy", "kernelVersion", "guidelineVersion"],
      "properties": {
        "version": {"type": "integer", "const": 1},
        "tier": {"type": "string", "const": "phase"},
        "phaseType": {"type": "string", "minLength": 1},
        "phaseId": {"type": ["string", "null"]},
        "steps": {"type": "array", "minItems": 1, "items": {"$ref": "#/definitions/stepId"}, "uniqueItems": true},
        "optionalFlags": {"type": "object", "additionalProperties": {"type": "boolean"}},
        "kernelInjectedSteps": {"type": "array", "items": {"$ref": "#/definitions/stepId"}, "uniqueItems": true},
        "planPolicy": {"$ref": "#/definitions/planPolicy"},
        "kernelVersion": {"$ref": "#/definitions/versionStamp"},
        "guidelineVersion": {"$ref": "#/definitions/versionStamp"},
        "validatedAt": {"type": "string"},
        "fallback": {"type": "string", "enum": ["canonical-chain"]}
      }
    },
    "waveBatchingPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "tier", "waves", "planPolicy", "kernelVersion", "guidelineVersion"],
      "properties": {
        "version": {"type": "integer", "const": 1},
        "tier": {"type": "string", "const": "wave"},
        "waves": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
        },
        "schedule": {"type": "array"},
        "planPolicy": {"$ref": "#/definitions/planPolicy"},
        "kernelVersion": {"$ref": "#/definitions/versionStamp"},
        "guidelineVersion": {"$ref": "#/definitions/versionStamp"},
        "parallelCeiling": {"type": "integer", "minimum": 1},
        "validatedAt": {"type": "string"},
        "fallback": {"type": "string", "enum": ["canonical-waves", "schedule", "contention-serialized"]}
      }
    },
    "planRejectionLog": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "threshold", "phases"],
      "properties": {
        "version": {"type": "integer", "const": 1},
        "threshold": {"type": "integer", "minimum": 1},
        "phases": {"type": "object"},
        "halt": {"type": ["object", "null"]}
      }
    }
  }
}

