{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/grdavies/shipwright/core/sw-reference/guidelines.schema.json",
  "title": "Shipwright phase guidelines artifact",
  "description": "Per-phase-type candidate step sets (PRD 022 R30).",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "guidelineVersion", "phaseTypes"],
  "properties": {
    "version": {"type": "integer", "const": 1},
    "guidelineVersion": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "description": {"type": "string"},
    "phaseTypes": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"$ref": "#/definitions/phaseGuideline"}
    }
  },
  "definitions": {
    "stepId": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
    "phaseGuideline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidateSteps", "requiredSteps", "optionalSteps", "allowedReorderings", "forbiddenDeviations", "floorRuleRefs"],
      "properties": {
        "candidateSteps": {"type": "array", "minItems": 1, "items": {"$ref": "#/definitions/stepId"}, "uniqueItems": true},
        "requiredSteps": {"type": "array", "items": {"$ref": "#/definitions/stepId"}, "uniqueItems": true},
        "optionalSteps": {"type": "array", "items": {"$ref": "#/definitions/stepId"}, "uniqueItems": true},
        "allowedReorderings": {"type": "array"},
        "forbiddenDeviations": {"type": "array"},
        "floorRuleRefs": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
      }
    }
  }
}
