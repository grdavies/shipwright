    "typecheck": "bash scripts/model-tier-check.sh",
    "test": "bash scripts/test/run-gate-fixtures.sh && bash scripts/test/run-pr-test-plan-manifest.sh && bash scripts/test/run-pr-test-plan-fixtures.sh && bash scripts/test/run-doc-link-fixtures.sh && bash scripts/test/run-impl-fixtures.sh && bash scripts/test/run-debug-fixtures.sh && bash scripts/test/run-feedback-fixtures.sh && bash scripts/test/run-improvement-fixtures.sh && bash scripts/test/run-memory-provider-fixtures.sh && bash scripts/test/run-memory-sot-fixtures.sh && bash scripts/test/run-code-review-fixtures.sh && bash scripts/test/run-persona-selection-fixtures.sh && bash scripts/test/run-onboarding-ux-fixtures.sh && bash scripts/test/run-deliver-fixtures.sh && bash scripts/test/run-deliver-loop-fixtures.sh && bash scripts/test/run-deliver-concurrency-fixtures.sh && bash scripts/test/run-orchestrator-fixtures.sh && bash scripts/test/run-branch-guard-fixtures.sh && bash scripts/test/run-state-fixtures.sh && bash scripts/test/run-secret-scan-fixtures.sh && bash scripts/test/run-ship-phase-fixtures.sh && bash scripts/test/run-tasks-currency-fixtures.sh && bash scripts/test/run-merge-queue-fixtures.sh && bash scripts/test/run-compound-completion-fixtures.sh && bash scripts/test/run-stabilize-merge-fixtures.sh && bash scripts/test/run-007-docs-fixtures.sh && bash scripts/test/run-007-fixtures.sh && bash scripts/test/run-living-doc-fixtures.sh && bash scripts/test/run-model-binding-fixtures.sh && bash scripts/test/run-retrospective-fixtures.sh && bash scripts/test/run-portability-setup-fixtures.sh && bash scripts/test/run-portability-boundary-fixtures.sh && bash scripts/test/run-base-resolution-fixtures.sh && bash scripts/test/run-portability-closure-fixtures.sh"
