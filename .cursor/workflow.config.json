{
  "$schema": "../.sw/config.schema.json",
  "defaultBaseBranch": "main",
  "stateFile": ".git/shipwright.json",
  "worktree": {
    "parallelCeiling": 4,
    "scaffold": {
      "portRangeStart": 9100,
      "portRangeEnd": 9199,
      "dbStrategy": "schema-prefix",
      "dbTemplate": ""
    }
  },
  "intraPhase": {
    "parallelBudget": 2,
    "harnessLimit": 8
  },
  "agentsFile": "AGENTS.md",
  "planningDir": "docs/prds",
  "prdsDir": "docs/prds",
  "decisionsDir": "docs/decisions",
  "tasksDir": "docs/prds",
  "doc": {
    "afterTasks": "confirm"
  },
  "compound": {
    "autonomy": "auto"
  },
  "verify": {
    "lint": "python3 scripts/model-routing-check.py",
    "typecheck": "python3 scripts/model-tier-check.py",
    "test": "python3 scripts/test/_runner.py verify"
  },
  "ci": {
    "prTestPlanManifest": "core/sw-reference/pr-test-plan.manifest.json"
  },
  "review": {
    "provider": "none"
  },
  "coderabbit": {
    "noDefer": true,
    "reviewGraceMinutes": 15
  },
  "checks": {
    "policy": "all",
    "treatNeutralAsPass": true,
    "neutralAllowlist": [],
    "watch": {
      "maxWaitMinutes": 20,
      "pollSeconds": 45
    }
  },
  "memory": {
    "provider": "recallium",
    "sourceOfTruth": "auto",
    "project": "shipwright",
    "defaultScope": "project",
    "connection": {
      "restBaseUrl": "http://localhost:8001"
    },
    "autoSync": {
      "enabled": true,
      "minTurns": 10,
      "minMinutes": 120
    },
    "guardrails": {
      "enforceBeforeSubmit": true,
      "requireRuleClass": false
    }
  },
  "models": {
    "tiers": {
      "cheap": "composer-2.5-fast",
      "build": "composer-2.5",
      "mid": "gpt-5.5-medium",
      "deep": "claude-opus-4-8-thinking-high"
    },
    "aliases": {
      "fast": "cheap"
    },
    "roles": {
      "builder": "build",
      "reviewer": "build"
    },
    "routing": {
      "commands": {
        "sw-amend": "deep",
        "sw-brainstorm": "deep",
        "sw-caveman": "cheap",
        "sw-cleanup": "cheap",
        "sw-commit": "cheap",
        "sw-compound": "mid",
        "sw-compound-ship": "inherit",
        "sw-debug": "build",
        "sw-deliver": "inherit",
        "sw-doc": "inherit",
        "sw-doc-review": "build",
        "sw-execute": "build",
        "sw-feedback": "build",
        "sw-feedback-close": "mid",
        "sw-freeze": "cheap",
        "sw-gaps": "mid",
        "sw-memory-audit": "mid",
        "sw-memory-export": "cheap",
        "sw-memory-import": "cheap",
        "sw-memory-sync": "mid",
        "sw-pr": "cheap",
        "sw-prd": "deep",
        "sw-ready": "cheap",
        "sw-retro": "mid",
        "sw-retrospective": "inherit",
        "sw-review": "build",
        "sw-setup": "cheap",
        "sw-ship": "inherit",
        "sw-simplify": "mid",
        "sw-stabilize": "build",
        "sw-start": "cheap",
        "sw-status": "cheap",
        "sw-tasks": "deep",
        "sw-triage": "cheap",
        "sw-verify": "cheap",
        "sw-watch-ci": "cheap",
        "sw-worktree": "cheap",
        "sw-init": "cheap"
      },
      "agents": {
        "sw-coherence-reviewer": "build",
        "sw-feasibility-reviewer": "build",
        "sw-scope-guardian-reviewer": "build",
        "sw-product-reviewer": "build",
        "sw-adversarial-reviewer": "build",
        "sw-docs-currency-reviewer": "build",
        "sw-security-reviewer": "build",
        "sw-design-reviewer": "build",
        "correctness": "deep",
        "security": "deep",
        "adversarial": "deep",
        "data-migration": "deep",
        "maintainability": "mid",
        "scope-fidelity": "mid",
        "testing": "mid",
        "performance": "mid",
        "api-contract": "mid",
        "reliability": "mid",
        "ui-ux": "mid",
        "type-design": "mid",
        "comment-accuracy": "mid",
        "ai-native": "mid"
      },
      "skills": {
        "brainstorm": "deep",
        "checks-gate": "cheap",
        "compound": "mid",
        "conductor": "inherit",
        "debug": "build",
        "deliver": "build",
        "doc-review": "inherit",
        "execute-discipline": "build",
        "feedback": "build",
        "feedback-closure": "mid",
        "gap-check": "mid",
        "git-workflow": "cheap",
        "living-status": "cheap",
        "memory": "cheap",
        "parallelism": "cheap",
        "prd": "deep",
        "rca-core": "build",
        "retro": "mid",
        "shipwright-state": "cheap",
        "simplify": "mid",
        "spec-rigor": "cheap",
        "spec-union": "cheap",
        "stabilize-loop": "build",
        "tasks": "deep",
        "triage": "cheap",
        "verification-gate": "cheap",
        "worktree": "cheap"
      }
    }
  },
  "configuredWith": {
    "shipwrightVersion": "1.7.0",
    "schemaVersion": "5c5d84df179e"
  },
  "deliver": {
    "autonomy": {
      "mode": "autonomous",
      "maxRunMinutes": 1440,
      "maxIterations": 500
    },
    "terminal": {
      "autonomy": "auto"
    }
  },
  "cleanup": {
    "autonomy": "auto"
  },
  "communication": {
    "defaultIntensity": "full",
    "routing": {
      "commands": {
        "sw-amend": "lite",
        "sw-brainstorm": "lite",
        "sw-caveman": "full",
        "sw-cleanup": "ultra",
        "sw-commit": "ultra",
        "sw-compound": "full",
        "sw-compound-ship": "full",
        "sw-debug": "inherit",
        "sw-deliver": "inherit",
        "sw-doc": "inherit",
        "sw-doc-review": "normal",
        "sw-execute": "full",
        "sw-feedback": "inherit",
        "sw-feedback-close": "ultra",
        "sw-freeze": "normal",
        "sw-gaps": "full",
        "sw-memory-audit": "ultra",
        "sw-memory-export": "ultra",
        "sw-memory-import": "ultra",
        "sw-memory-sync": "ultra",
        "sw-pr": "ultra",
        "sw-prd": "lite",
        "sw-ready": "normal",
        "sw-retro": "lite",
        "sw-retrospective": "full",
        "sw-review": "full",
        "sw-setup": "ultra",
        "sw-init": "ultra",
        "sw-ship": "inherit",
        "sw-simplify": "full",
        "sw-stabilize": "full",
        "sw-start": "ultra",
        "sw-status": "ultra",
        "sw-tasks": "lite",
        "sw-triage": "ultra",
        "sw-verify": "ultra",
        "sw-watch-ci": "ultra",
        "sw-worktree": "ultra"
      },
      "skills": {
        "brainstorm": "lite",
        "checks-gate": "ultra",
        "compound": "full",
        "conductor": "inherit",
        "debug": "inherit",
        "deliver": "inherit",
        "doc-review": "normal",
        "execute-discipline": "full",
        "feedback": "inherit",
        "feedback-closure": "ultra",
        "gap-check": "full",
        "living-status": "ultra",
        "memory": "ultra",
        "parallelism": "ultra",
        "prd": "lite",
        "rca-core": "full",
        "retro": "lite",
        "shipwright-state": "ultra",
        "simplify": "full",
        "spec-rigor": "normal",
        "spec-union": "normal",
        "stabilize-loop": "full",
        "tasks": "lite",
        "triage": "ultra",
        "verification-gate": "ultra",
        "worktree": "ultra"
      },
      "agents": {
        "sw-coherence-reviewer": "full",
        "sw-feasibility-reviewer": "full",
        "sw-scope-guardian-reviewer": "full",
        "sw-product-reviewer": "full",
        "sw-adversarial-reviewer": "full",
        "sw-docs-currency-reviewer": "full",
        "sw-security-reviewer": "full",
        "sw-design-reviewer": "full",
        "correctness": "full",
        "security": "full",
        "adversarial": "full",
        "data-migration": "full",
        "maintainability": "normal",
        "scope-fidelity": "normal",
        "testing": "normal",
        "performance": "normal",
        "api-contract": "normal",
        "reliability": "normal",
        "ui-ux": "normal",
        "type-design": "normal",
        "comment-accuracy": "normal",
        "ai-native": "normal"
      }
    }
  },
  "delegation": {
    "mode": "bind-only"
  },
  "orchestration": {
    "planPolicy": "proposed"
  },
  "host": {
    "provider": "github",
    "remote": "origin",
    "tokenEnv": "GITHUB_TOKEN",
    "rateLimit": {
      "maxAttempts": 5,
      "baseBackoffMs": 1000,
      "capBackoffMs": 60000,
      "maxCumulativeWaitMs": 300000,
      "jitter": true,
      "nearLimitThreshold": 5,
      "mutatingMinDelayMs": 1000
    }
  },
  "planning": {
    "store": {
      "backend": "memory"
    },
    "visibilityProfile": "all-private",
    "privacyAck": {
      "required": true,
      "recordedAt": null,
      "reason": "public-origin-remote"
    }
  }
}
