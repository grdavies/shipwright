{
  "$schema": "../.sw/config.schema.json",
  "defaultBaseBranch": "main",
  "stateFile": ".git/shipwright.json",
  "worktree": {
    "parallelCeiling": 4,
    "scaffold": {
      "portRangeStart": 9100,
      "portRangeEnd": 9199,
      "dbStrategy": "schema-prefix",
      "dbTemplate": ""
    }
  },
  "agentsFile": "AGENTS.md",
  "prdsDir": "docs/prds",
  "decisionsDir": "docs/decisions",
  "tasksDir": "docs/prds",
  "doc": {
    "afterTasks": "confirm"
  },
  "verify": {
    "lint": "echo 'no lint configured'",
    "typecheck": "echo 'no typecheck configured'",
    "test": "bash scripts/test/run-gate-fixtures.sh && bash scripts/test/run-doc-fixtures.sh && bash scripts/test/run-impl-fixtures.sh && bash scripts/test/run-debug-fixtures.sh && bash scripts/test/run-feedback-fixtures.sh && bash scripts/test/run-improvement-fixtures.sh && bash scripts/test/run-memory-provider-fixtures.sh && bash scripts/test/run-code-review-fixtures.sh && bash scripts/test/run-persona-selection-fixtures.sh && bash scripts/test/run-onboarding-ux-fixtures.sh && bash scripts/test/run-deliver-fixtures.sh"
  },
  "review": {
    "provider": "none"
  },
  "coderabbit": {
    "noDefer": true,
    "reviewGraceMinutes": 15
  },
  "checks": {
    "policy": "all",
    "treatNeutralAsPass": true,
    "neutralAllowlist": [],
    "watch": {
      "maxWaitMinutes": 20,
      "pollSeconds": 45
    }
  },
  "memory": {
    "provider": "recallium",
    "project": "shipwright",
    "defaultScope": "project",
    "connection": {
      "restBaseUrl": "http://localhost:8001"
    },
    "autoSync": {
      "enabled": true,
      "minTurns": 10,
      "minMinutes": 120
    },
    "guardrails": {
      "enforceBeforeSubmit": true,
      "requireRuleClass": false
    }
  }
}
