  "ci": {
    "prTestPlanManifest": "core/sw-reference/pr-test-plan.manifest.json"
  },
  "review": {
    "provider": "none"
  },
  "coderabbit": {
    "noDefer": true,
    "reviewGraceMinutes": 15
  },
  "checks": {
    "policy": "all",
    "treatNeutralAsPass": true,
    "neutralAllowlist": [],
    "watch": {
      "maxWaitMinutes": 20,
      "pollSeconds": 45
    }
  },
  "memory": {
    "provider": "recallium",
    "project": "shipwright",
    "defaultScope": "project",
    "connection": {
      "restBaseUrl": "http://localhost:8001"
    },
    "autoSync": {
      "enabled": true,
      "minTurns": 10,
      "minMinutes": 120
    },
    "guardrails": {
      "enforceBeforeSubmit": true,
      "requireRuleClass": false
    }
  },
  "models": {
    "tiers": {
      "cheap": "composer-2.5-fast",
      "build": "composer-2.5",
      "mid": "gpt-5.5-medium",
      "deep": "claude-opus-4-8-thinking-high"
