{
  "$schema": "../docs/config.schema.json",
  "defaultBaseBranch": "main",
  "stateFile": ".git/phase-flow.json",
  "agentsFile": "AGENTS.md",
  "prdsDir": "docs/plans",
  "tasksDir": "docs/plans",
  "verify": {
    "lint": "echo 'no lint configured'",
    "typecheck": "echo 'no typecheck configured'",
    "test": "bash scripts/test/run-gate-fixtures.sh"
  },
  "review": {
    "provider": "none"
  },
  "coderabbit": {
    "noDefer": true,
    "reviewGraceMinutes": 15
  },
  "checks": {
    "policy": "all",
    "treatNeutralAsPass": true,
    "neutralAllowlist": [],
    "watch": {
      "maxWaitMinutes": 20,
      "pollSeconds": 45
    }
  },
  "memory": {
    "provider": "recallium",
    "project": "currsor-phase-flow-2",
    "defaultScope": "project",
    "connection": {
      "restBaseUrl": "http://localhost:8001"
    },
    "autoSync": {
      "enabled": true,
      "minTurns": 10,
      "minMinutes": 120
    },
    "guardrails": {
      "enforceBeforeSubmit": true,
      "requireRuleClass": false
    }
  }
}
