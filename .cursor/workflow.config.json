        "reliability": "mid",
        "ui-ux": "mid",
        "type-design": "mid",
        "comment-accuracy": "mid",
        "ai-native": "mid"
      },
      "skills": {
        "brainstorm": "deep",
        "checks-gate": "cheap",
        "compound": "mid",
        "debug": "build",
        "deliver": "build",
        "doc-review": "inherit",
        "execute-discipline": "build",
        "feedback": "build",
        "feedback-closure": "mid",
        "gap-check": "mid",
        "living-status": "cheap",
