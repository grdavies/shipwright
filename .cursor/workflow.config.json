{
  "$schema": "../.sw/config.schema.json",
  "defaultBaseBranch": "main",
  "stateFile": ".git/shipwright.json",
  "worktree": {
    "parallelCeiling": 4,
    "scaffold": {
      "portRangeStart": 9100,
      "portRangeEnd": 9199,
      "dbStrategy": "schema-prefix",
      "dbTemplate": ""
    }
  },
  "agentsFile": "AGENTS.md",
  "prdsDir": "docs/prds",
  "decisionsDir": "docs/decisions",
  "tasksDir": "docs/prds",
  "doc": {
    "afterTasks": "confirm"
  },
  "verify": {
    "lint": "echo 'no lint configured'",
    "typecheck": "echo 'no typecheck configured'",
    "test": "bash scripts/test/run-gate-fixtures.sh && bash scripts/test/run-doc-fixtures.sh && bash scripts/test/run-doc-link-fixtures.sh && bash scripts/test/run-impl-fixtures.sh && bash scripts/test/run-debug-fixtures.sh && bash scripts/test/run-feedback-fixtures.sh && bash scripts/test/run-improvement-fixtures.sh && bash scripts/test/run-memory-provider-fixtures.sh && bash scripts/test/run-code-review-fixtures.sh && bash scripts/test/run-persona-selection-fixtures.sh && bash scripts/test/run-onboarding-ux-fixtures.sh && bash scripts/test/run-deliver-fixtures.sh && bash scripts/test/run-deliver-loop-fixtures.sh && bash scripts/test/run-cleanup-fixtures.sh && bash scripts/test/run-orchestrator-fixtures.sh && bash scripts/test/run-branch-guard-fixtures.sh && bash scripts/test/run-state-fixtures.sh && bash scripts/test/run-secret-scan-fixtures.sh && bash scripts/test/run-ship-phase-fixtures.sh && bash scripts/test/run-tasks-currency-fixtures.sh && bash scripts/test/run-merge-queue-fixtures.sh && bash scripts/test/run-compound-completion-fixtures.sh && bash scripts/test/run-stabilize-merge-fixtures.sh && bash scripts/test/run-007-docs-fixtures.sh && bash scripts/test/run-007-fixtures.sh && bash scripts/test/run-living-doc-fixtures.sh && bash scripts/test/run-ux-polish-fixtures.sh"
  },
  "review": {
    "provider": "none"
  },
  "coderabbit": {
    "noDefer": true,
    "reviewGraceMinutes": 15
  },
  "checks": {
    "policy": "all",
    "treatNeutralAsPass": true,
    "neutralAllowlist": [],
    "watch": {
      "maxWaitMinutes": 20,
      "pollSeconds": 45
    }
  },
  "memory": {
    "provider": "recallium",
    "project": "shipwright",
    "defaultScope": "project",
    "connection": {
      "restBaseUrl": "http://localhost:8001"
    },
    "autoSync": {
      "enabled": true,
      "minTurns": 10,
      "minMinutes": 120
    },
    "guardrails": {
      "enforceBeforeSubmit": true,
      "requireRuleClass": false
    }
  },
  "models": {
    "tiers": {
      "cheap": "composer-2.5-fast",
      "build": "composer-2.5",
      "mid": "gpt-5.5-medium",
      "deep": "claude-opus-4-8-thinking-high"
    },
    "aliases": {
      "fast": "cheap"
    },
    "roles": {
      "builder": "build",
      "reviewer": "build"
    },
    "routing": {
      "commands": {
        "sw-amend": "deep",
        "sw-brainstorm": "deep",
        "sw-caveman": "cheap",
        "sw-cleanup": "cheap",
        "sw-commit": "cheap",
        "sw-compound": "mid",
        "sw-compound-ship": "inherit",
        "sw-debug": "build",
        "sw-deliver": "inherit",
        "sw-doc": "inherit",
        "sw-doc-review": "build",
        "sw-execute": "build",
        "sw-feedback": "build",
        "sw-feedback-close": "mid",
        "sw-freeze": "cheap",
        "sw-gaps": "mid",
        "sw-memory-audit": "mid",
        "sw-memory-export": "cheap",
        "sw-memory-import": "cheap",
        "sw-memory-sync": "mid",
        "sw-pr": "cheap",
        "sw-prd": "deep",
        "sw-ready": "cheap",
        "sw-retro": "mid",
        "sw-review": "build",
        "sw-setup": "cheap",
        "sw-ship": "inherit",
        "sw-simplify": "mid",
        "sw-stabilize": "build",
        "sw-start": "cheap",
        "sw-status": "cheap",
        "sw-tasks": "deep",
        "sw-triage": "cheap",
        "sw-verify": "cheap",
        "sw-watch-ci": "cheap",
        "sw-worktree": "cheap"
      },
      "skills": {
        "brainstorm": "deep",
        "checks-gate": "cheap",
        "compound": "mid",
        "debug": "build",
        "deliver": "build",
        "doc-review": "inherit",
        "execute-discipline": "build",
        "feedback": "build",
        "feedback-closure": "mid",
        "gap-check": "mid",
        "living-status": "cheap",
        "memory": "cheap",
        "parallelism": "cheap",
        "prd": "deep",
        "rca-core": "build",
        "retro": "mid",
        "shipwright-state": "cheap",
        "simplify": "mid",
        "spec-rigor": "cheap",
        "spec-union": "cheap",
        "stabilize-loop": "build",
        "tasks": "deep",
        "triage": "cheap",
        "verification-gate": "cheap",
        "worktree": "cheap"
      }
    }
  }
}
