#!/usr/bin/env python3
import os, re, subprocess, sys
from pathlib import Path
ROOT = Path(__file__).resolve().parent.parent.parent
env = os.environ.copy(); env["ROOT"]=str(ROOT); env["PYTHONPATH"]=str(ROOT/"scripts")
_src = """#!/usr/bin/env bash
set -euo pipefail
ROOT="/Volumes/External Storage/GitHub/shipwright/.sw-worktrees/cross-platform-python-standardization-phase-hooks-security-filters-providers-l"
FAIL=0
for tree in dist/cursor/providers dist/claude-code/providers dist/cursor/core/hooks dist/claude-code/core/hooks dist/cursor/hooks dist/claude-code/hooks; do
  if [ -d "$ROOT/$tree" ]; then
    while IFS= read -r f; do
      echo "FAIL shell surface $f"; FAIL=1
    done < <(find "$ROOT/$tree" -name '*.sh' 2>/dev/null)
  fi
done
for hook in pre-commit.py pre-push.py commit-msg.py pre-commit-frozen.py pre-commit-completed-unit.py; do
  test -f "$ROOT/core/hooks/$hook" || { echo "FAIL missing core/hooks/$hook"; FAIL=1; }
done
[ "$FAIL" -eq 0 ] || exit 1
echo "OK  dist-no-shell"
"""
src = _src.replace("#!/usr/bin/env bash", "").replace("set -euo pipefail", "")
src = re.sub(r'ROOT="[^"]*"', 'ROOT="' + str(ROOT) + '"', src, count=1)
src = src.replace('.sh"', '.py"').replace('bash "', 'python3 "')
rc = subprocess.run(["bash", "-c", src], cwd=str(ROOT), env=env, shell=False).returncode
if rc == 0:
    print("OK  dist-no-shell")
raise SystemExit(rc or 0)
