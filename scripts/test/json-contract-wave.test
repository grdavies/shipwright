#!/usr/bin/env python3
import os, re, subprocess, sys
from pathlib import Path
ROOT = Path(__file__).resolve().parent.parent.parent
env = os.environ.copy(); env["ROOT"]=str(ROOT); env["PYTHONPATH"]=str(ROOT/"scripts")
_src = """#!/usr/bin/env bash
# JSON/dispatch contract for ported wave.py (PRD 042 R24 subset).
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
export PYTHONPATH="$ROOT/scripts${PYTHONPATH:+:$PYTHONPATH}"
FAIL=0

if python3 "$ROOT/scripts/wave.py" plan validate --help >/dev/null 2>&1; then
  echo "OK  wave-help-routes"
else
  # wave has no global --help; test a lightweight route instead
  if python3 "$ROOT/scripts/wave.py" state get --help >/dev/null 2>&1 ||      python3 -c "import wave; assert hasattr(wave,'dispatch')"; then
    echo "OK  wave-module-import"
  else
    echo "FAIL wave-dispatch"
    FAIL=1
  fi
fi

# Dispatcher resolves without bash wave.sh
if python3 -c "
from pathlib import Path
import subprocess, sys
root=Path('$ROOT')
proc=subprocess.run([sys.executable, str(root/'scripts/wave.py'), 'assert-entry'], cwd=str(root), capture_output=True, text=True)
# assert-entry may fail without worktree context; ensure python entry ran
assert 'wave.sh' not in (proc.stderr or '')
print('ok')
"; then echo "OK  wave-no-shell-dispatch"; else echo "FAIL wave-no-shell-dispatch"; FAIL=1; fi

exit "$FAIL"
"""
src = _src.replace("#!/usr/bin/env bash", "").replace("set -euo pipefail", "")
src = re.sub(r'ROOT="[^"]*"', 'ROOT="' + str(ROOT) + '"', src, count=1)
src = src.replace('.sh"', '.py"').replace('bash "', 'python3 "')
rc = subprocess.run(["bash", "-c", src], cwd=str(ROOT), env=env, shell=False).returncode
if rc == 0:
    print("OK  json-contract-wave")
raise SystemExit(rc or 0)
