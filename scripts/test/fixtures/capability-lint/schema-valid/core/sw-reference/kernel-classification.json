{
  "version": 1,
  "kernelVersion": "1.0.0",
  "description": "Single-sourced kernel vs plan-policy classification for Shipwright orchestration (PRD 022).",
  "kernelChokepoints": [
    {
      "id": "scoped-run-identity",
      "layer": "kernel",
      "enforcedBy": [
        "shipwright-state.py",
        "ship-phase-steps.py"
      ],
      "mustPrecede": [
        "merge-push",
        "gate-check"
      ]
    },
    {
      "id": "durable-state-transitions",
      "layer": "kernel",
      "enforcedBy": [
        "shipwright-state.py",
        "wave_deliver_loop.py"
      ],
      "mustPrecede": [
        "merge-push"
      ]
    },
    {
      "id": "verification-gate",
      "layer": "kernel",
      "stepId": "verification-gate",
      "inCanonicalChain": true,
      "mustPrecede": [
        "sw-commit",
        "merge-push"
      ]
    },
    {
      "id": "check-gate",
      "layer": "kernel",
      "enforcedBy": [
        "check-gate.py"
      ],
      "traceAnchors": [
        "sw-stabilize",
        "sw-ready"
      ],
      "mustPrecede": [
        "merge-ready",
        "merge-push"
      ]
    },
    {
      "id": "merge-queue-journal",
      "layer": "kernel",
      "enforcedBy": [
        "wave_merge.py"
      ],
      "mustPrecede": [
        "merge-push"
      ]
    },
    {
      "id": "merge-single-flight-lock",
      "layer": "kernel",
      "enforcedBy": [
        "O_EXCL"
      ],
      "mustPrecede": [
        "merge-push"
      ]
    },
    {
      "id": "merge-gate-check-barrier",
      "layer": "kernel",
      "mustPrecede": [
        "merge-push"
      ]
    },
    {
      "id": "no-main-auto-merge",
      "layer": "kernel",
      "enforcedBy": [
        "sw-ready",
        "sw-deliver"
      ],
      "mustPrecede": []
    },
    {
      "id": "human-terminal-merge-gate",
      "layer": "kernel",
      "traceAnchors": [
        "sw-ready"
      ],
      "mustPrecede": [
        "merge-push"
      ]
    },
    {
      "id": "git-push-secret-scan",
      "layer": "kernel",
      "enforcedBy": [
        "git-push.py"
      ],
      "traceAnchors": [
        "sw-pr"
      ],
      "mustPrecede": [
        "merge-push"
      ]
    },
    {
      "id": "memory-redaction-chokepoint",
      "layer": "kernel",
      "enforcedBy": [
        "memory-redact.py"
      ],
      "mustPrecede": [
        "memory-preflight",
        "dispatch"
      ]
    },
    {
      "id": "memory-preflight-routing",
      "layer": "kernel",
      "enforcedBy": [
        "memory-preflight"
      ],
      "mustPrecede": [
        "memory-write"
      ]
    },
    {
      "id": "range-scoped-redaction-guard",
      "layer": "kernel",
      "mustPrecede": [
        "merge-push"
      ]
    },
    {
      "id": "beforeSubmitPrompt-guardrails",
      "layer": "kernel",
      "nonSelectable": true,
      "nonReorderable": true,
      "enforcedBy": [
        "before-submit-guardrails.py"
      ]
    },
    {
      "id": "orchestrator-excl-lock",
      "layer": "kernel",
      "enforcedBy": [
        "sw-deliver.lock"
      ],
      "mustPrecede": [
        "merge-push"
      ]
    },
    {
      "id": "living-doc-excl-lock",
      "layer": "kernel",
      "mustPrecede": [
        "living-doc-merge"
      ]
    }
  ],
