  "canonicalPhaseChains": {
    "sw-ship": [
      "sw-tmp-init",
      "sw-execute",
      "sw-verify",
      "verification-gate",
      "sw-review",
      "sw-simplify",
      "gap-check",
      "sw-commit",
      "sw-pr",
      "sw-watch-ci",
      "sw-stabilize",
      "sw-ready",
      "sw-tmp-clean"
    ]
  },
  "orderingInvariants": [
    {
      "before": "sw-tmp-init",
      "after": "sw-execute"
    },
    {
      "before": "sw-execute",
      "after": "sw-verify"
    },
    {
      "before": "sw-verify",
      "after": "verification-gate"
    },
    {
      "before": "verification-gate",
      "after": "sw-commit"
    },
    {
      "before": "sw-review",
      "after": "sw-commit"
    },
    {
      "before": "sw-simplify",
      "after": "sw-commit"
    },
    {
      "before": "gap-check",
      "after": "sw-commit"
    },
    {
      "before": "sw-commit",
      "after": "sw-pr"
    },
    {
      "before": "sw-pr",
      "after": "sw-watch-ci"
    },
    {
      "before": "sw-watch-ci",
      "after": "sw-stabilize"
    },
    {
      "before": "sw-stabilize",
      "after": "sw-ready"
    },
    {
      "before": "sw-ready",
      "after": "sw-tmp-clean"
    },
    {
      "before": "verification-gate",
      "after": "merge-push",
      "kind": "chokepoint"
    },
    {
      "before": "check-gate",
      "after": "merge-push",
      "kind": "chokepoint"
    },
    {
      "before": "git-push-secret-scan",
      "after": "merge-push",
      "kind": "chokepoint"
    }
  ],
  "orchestratorStepRegistry": {
    "sw-ship": {
      "chainKey": "sw-ship",
      "sourcePaths": [
        "core/commands/sw-ship.md"
      ]
    },
    "sw-deliver": {
      "delegatesTo": "sw-ship",
      "sourcePaths": [
        "core/commands/sw-deliver.md",
        "core/skills/conductor/SKILL.md"
      ]
    },
    "sw-doc": {
      "chainKey": "doc",
      "sourcePaths": [
        "core/commands/sw-doc.md"
      ]
    },
    "sw-debug": {
      "chainKey": "debug",
      "sourcePaths": [
        "core/commands/sw-debug.md",
        "core/skills/debug/SKILL.md"
      ]
    },
    "sw-feedback": {
      "chainKey": "feedback",
      "sourcePaths": [
        "core/commands/sw-feedback.md",
        "core/skills/feedback/SKILL.md"
      ]
    }
  },
  "floorMatrix": {
    "version": 1,
    "rules": [
      {
        "id": "security-sensitive-paths",
        "description": "Force sw-review when work touches auth or payments surfaces",
        "mandatorySteps": [
          "sw-review"
        ],
        "orderingConstraints": [
          {
            "step": "sw-review",
            "mustPrecede": "sw-commit"
          }
        ],
        "triggers": {
          "anyOf": [
            {
              "type": "path_glob",
              "source": "task_file_paths",
              "globs": [
                "auth/**",
                "payments/**"
              ]
            },
            {
              "type": "path_glob",
              "source": "signal_context_file_paths",
              "globs": [
                "auth/**",
                "payments/**"
              ]
            }
          ]
        },
        "triageTagsAloneInsufficient": true
      },
      {
        "id": "kernel-scripts-providers",
        "description": "Force sw-review for kernel scripts and provider changes",
        "mandatorySteps": [
          "sw-review"
        ],
        "orderingConstraints": [
          {
            "step": "sw-review",
            "mustPrecede": "sw-commit"
          }
        ],
        "triggers": {
          "anyOf": [
            {
              "type": "path_glob",
              "source": "task_file_paths",
              "globs": [
                "scripts/git-push.py",
                "scripts/wave_*",
                "core/providers/**"
              ]
            },
            {
              "type": "path_glob",
              "source": "signal_context_file_paths",
              "globs": [
                "scripts/git-push.py",
                "scripts/wave_*",
                "core/providers/**"
              ]
            }
          ]
        },
        "triageTagsAloneInsufficient": true
      },
      {
        "id": "hooks-manifest",
        "description": "Force sw-review when hooks.json is in scope",
        "mandatorySteps": [
          "sw-review"
        ],
        "orderingConstraints": [
          {
            "step": "sw-review",
            "mustPrecede": "sw-commit"
          }
        ],
        "triggers": {
          "anyOf": [
            {
              "type": "path_glob",
              "source": "task_file_paths",
              "globs": [
                "hooks.json",
                "**/hooks.json"
              ]
            },
            {
              "type": "path_glob",
              "source": "signal_context_file_paths",
              "globs": [
                "hooks.json",
                "**/hooks.json"
              ]
            }
          ]
        },
        "triageTagsAloneInsufficient": true
      }
    ]
  },
