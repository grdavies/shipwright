#!/usr/bin/env bash
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
python3 <<PY
import json
from pathlib import Path
root = Path("$ROOT")
ledger = json.loads((root / "core/sw-reference/script-port-ledger.json").read_text())
entries = {e["path"] for e in ledger["entries"]}
found=set()
for rel in ["scripts","scripts/test","core/scripts","core/hooks","core/providers"]:
    base=root/rel
    if base.is_dir():
        for p in base.rglob("*.sh"):
            found.add(p.relative_to(root).as_posix())
missing=found-entries
if missing:
    raise SystemExit(f"undisposed: {sorted(missing)[:5]}")
print("OK ledger", len(found))
PY
echo "OK  script-ledger-reconcile"
