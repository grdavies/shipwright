#!/usr/bin/env python3
"""Poll primitive smoke (R15) — native Python."""
from __future__ import annotations

import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent.parent
sys.path.insert(0, str(ROOT / "scripts"))

from _sw.poll import PollConfig, PollTimeoutError, poll_until  # noqa: E402


def main() -> int:
    n = 0

    def pred() -> bool:
        nonlocal n
        n += 1
        return n >= 2

    cfg = PollConfig(interval_seconds=0.01, max_wait_seconds=1.0, jitter="none")
    poll_until(pred, config=cfg, timeout_seconds=1.0)
    try:
        poll_until(lambda: False, config=cfg, timeout_seconds=0.05)
    except PollTimeoutError:
        pass
    else:
        print("FAIL poll-until: expected PollTimeoutError")
        return 1
    print("OK  poll-until")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
