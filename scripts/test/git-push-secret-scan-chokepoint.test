#!/usr/bin/env python3
"""Regression fixture for gap-004 Defect C — native Python.

`scripts/git-push.py` is the sole sanctioned push chokepoint (conductor R23:
"secret-scan pre-push"). A prior regression called `secret_scan.main(["pre-push"])`
against a zero-argument `main()`, raising `TypeError` on every invocation and
forcing a raw `git push` fallback that silently skipped the secret-scan gate.

This guards, without ever invoking real `git push` or network I/O:
1. `secret-scan.py pre-push` (the canonical chokepoint entrypoint `git-push.py`
   subprocess-invokes) runs cleanly — no TypeError / non-zero from signature drift.
2. `git-push.py:main()` never reaches `git push` when the secret-scan subprocess
   reports a non-zero exit code.
"""
from __future__ import annotations

import importlib.util
import subprocess
import sys
from pathlib import Path
from unittest import mock

ROOT = Path(__file__).resolve().parent.parent.parent
sys.path.insert(0, str(ROOT / "scripts"))


def _load(name: str, rel: str):
    spec = importlib.util.spec_from_file_location(name, ROOT / rel)
    mod = importlib.util.module_from_spec(spec)
    assert spec.loader is not None
    spec.loader.exec_module(mod)
    return mod


def main() -> int:
    failures: list[str] = []

    scan = subprocess.run(
        [sys.executable, str(ROOT / "scripts" / "secret-scan.py"), "pre-push"],
        capture_output=True,
        text=True,
    )
    if scan.returncode != 0:
        failures.append(f"secret-scan.py pre-push exited {scan.returncode}: {scan.stderr.strip()[:200]!r}")

    git_push = _load("git_push_fixture", "scripts/git-push.py")

    push_calls: list[list[str]] = []

    def fake_run(cmd, *args, **kwargs):
        if cmd[:2] == ["git", "push"] or (len(cmd) >= 2 and cmd[0] == "git" and cmd[1] == "push"):
            push_calls.append(cmd)
            return subprocess.CompletedProcess(cmd, 0)
        if cmd[:2] == ["git", "rev-parse"]:
            return subprocess.CompletedProcess(cmd, 0, stdout=str(ROOT), stderr="")
        if len(cmd) >= 2 and Path(str(cmd[1])).name == "secret-scan.py":
            return subprocess.CompletedProcess(cmd, 1, stdout="", stderr="FAIL secret found (fixture)")
        if len(cmd) >= 2 and Path(str(cmd[1])).name == "planning_materialize.py":
            return subprocess.CompletedProcess(cmd, 0)
        return subprocess.CompletedProcess(cmd, 0)

    with mock.patch.object(git_push.subprocess, "run", side_effect=fake_run):
        rc = git_push.main([])

    if rc == 0:
        failures.append("git-push.py main() returned 0 despite a failing secret-scan stub")
    if push_calls:
        failures.append(f"git push was invoked despite a failing secret-scan stub: {push_calls}")

    if failures:
        for failure in failures:
            print(f"FAIL git-push-secret-scan-chokepoint: {failure}")
        return 1
    print("OK  git-push-secret-scan-chokepoint")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
