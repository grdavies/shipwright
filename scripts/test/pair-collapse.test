#!/usr/bin/env python3
import os, re, subprocess, sys
from pathlib import Path
ROOT = Path(__file__).resolve().parent.parent.parent
env = os.environ.copy(); env["ROOT"]=str(ROOT); env["PYTHONPATH"]=str(ROOT/"scripts")
_src = """#!/usr/bin/env bash
# Collapsed .sh/.py sibling pairs (PRD 042 R21).
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
FAIL=0
ok() { echo "OK  $1"; }
bad() { echo "FAIL $1"; FAIL=1; }

PAIRS=(scripts/check-gate scripts/planning_paths scripts/visibility-callsite-lint core/scripts/planning_paths core/scripts/visibility-callsite-lint)
for base in "${PAIRS[@]}"; do
  sh="$ROOT/${base}.sh"; py="$ROOT/${base}.py"
  if [[ -f "$sh" ]]; then bad "sibling-sh-remains: ${base}.sh"
  elif [[ -f "$py" ]]; then ok "collapsed-${base##*/}"
  else bad "missing-python-module: ${base}.py"; fi
done

for tree in core/commands core/skills core/rules; do
  base="$ROOT/$tree"; [[ -d "$base" ]] || continue
  if grep -rE 'scripts/(check-gate|planning_paths|visibility-callsite-lint)\.sh' "$base" >/dev/null 2>&1; then
    bad "stale-sh-caller-in-$tree"
  fi
done
ok "no-stale-sh-callers"
exit "$FAIL"
"""
src = _src.replace("#!/usr/bin/env bash", "").replace("set -euo pipefail", "")
src = re.sub(r'ROOT="[^"]*"', 'ROOT="' + str(ROOT) + '"', src, count=1)
src = src.replace('.sh"', '.py"').replace('bash "', 'python3 "')
rc = subprocess.run(["bash", "-c", src], cwd=str(ROOT), env=env, shell=False).returncode
if rc == 0:
    print("OK  pair-collapse")
raise SystemExit(rc or 0)
