#!/usr/bin/env python3
"""Host adapter parity (R25/R39) — native Python."""
from __future__ import annotations

import json
import os
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent.parent


def run_host(*args: str) -> dict:
    env = os.environ.copy()
    env["PYTHONPATH"] = str(ROOT / "scripts")
    env.setdefault("GITHUB_TOKEN", "gh_fixture_token_for_tests")
    env.setdefault("SW_HOST_FIXTURE", "green")
    completed = subprocess.run(
        [sys.executable, str(ROOT / "scripts" / "host.py"), "--root", str(ROOT), *args],
        cwd=str(ROOT),
        env=env,
        capture_output=True,
        text=True,
        check=False,
    )
    if completed.returncode != 0:
        print(completed.stderr or completed.stdout, file=sys.stderr)
        raise RuntimeError(f"host.py failed exit={completed.returncode}")
    return json.loads(completed.stdout)


def main() -> int:
    out = run_host("pr-list", "--head", "feat/x", "--base", "main", "--state", "open")
    if out.get("verdict") != "ok" or not isinstance(out.get("data"), list):
        print(f"FAIL host-adapter-parity pr-list: {out}")
        return 1
    out2 = run_host("pr-create", "--title", "t", "--body", "b", "--head", "feat/x", "--base", "main")
    if out2.get("verdict") != "ok" or not out2.get("data", {}).get("number"):
        print(f"FAIL host-adapter-parity pr-create: {out2}")
        return 1
    print("OK  host-adapter-parity")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
