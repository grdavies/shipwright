#!/usr/bin/env python3
import os, re, subprocess, sys
from pathlib import Path
ROOT = Path(__file__).resolve().parent.parent.parent
env = os.environ.copy(); env["ROOT"]=str(ROOT); env["PYTHONPATH"]=str(ROOT/"scripts")
_src = """#!/usr/bin/env bash
# Idempotent COMPLETION-LOG writer (PRD 042 R20).
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
export PYTHONPATH="$ROOT/scripts${PYTHONPATH:+:$PYTHONPATH}"
FAIL=0
ok() { echo "OK  $1"; }
bad() { echo "FAIL $1"; FAIL=1; }

FIX=$(mktemp -d)
mkdir -p "$FIX/docs/prds"
cp "$ROOT/docs/prds/COMPLETION-LOG.md" "$FIX/docs/prds/"
OUT1=$(cd "$FIX" && python3 "$ROOT/scripts/reconcile.py" append-log-idempotent --prd 099 --phase all --sha deadbeef --notes "test")
OUT2=$(cd "$FIX" && python3 "$ROOT/scripts/reconcile.py" append-log-idempotent --prd 099 --phase all --sha deadbeef --notes "test")
if echo "$OUT1" | python3 -c "import json,sys; d=json.load(sys.stdin); assert d.get('appended') is True" &&    echo "$OUT2" | python3 -c "import json,sys; d=json.load(sys.stdin); assert d.get('skipped') is True"; then
  ok "completion-log-idempotent"
else
  bad "completion-log-idempotent"
fi
rm -rf "$FIX"
exit "$FAIL"
"""
src = _src.replace("#!/usr/bin/env bash", "").replace("set -euo pipefail", "")
src = re.sub(r'ROOT="[^"]*"', 'ROOT="' + str(ROOT) + '"', src, count=1)
src = src.replace('.sh"', '.py"').replace('bash "', 'python3 "')
rc = subprocess.run(["bash", "-c", src], cwd=str(ROOT), env=env, shell=False).returncode
if rc == 0:
    print("OK  completion-log-idempotent")
raise SystemExit(rc or 0)
