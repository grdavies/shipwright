#!/usr/bin/env python3
import os, re, subprocess, sys
from pathlib import Path
ROOT = Path(__file__).resolve().parent.parent.parent
env = os.environ.copy(); env["ROOT"]=str(ROOT); env["PYTHONPATH"]=str(ROOT/"scripts")
_src = """#!/usr/bin/env bash
# Zero jq invocations on phase-5 production surfaces (PRD 042 R7 complete).
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
FAIL=0
ok() { echo "OK  $1"; }
bad() { echo "FAIL $1"; FAIL=1; }

SCAN_DIRS=(scripts core/scripts)
for dir in "${SCAN_DIRS[@]}"; do
  base="$ROOT/$dir"
  [[ -d "$base" ]] || continue
  while IFS= read -r -d '' f; do
    [[ "$f" == *"/test/"* ]] && continue
    [[ "$f" == *"/_sw/"* ]] && continue
    if grep -E '\bjq\b' "$f" >/dev/null 2>&1; then
      bad "jq-in-production: ${f#"$ROOT/"}"
    fi
  done < <(find "$base" -type f \( -name '*.sh' -o -name '*.py' \) -print0 2>/dev/null)
done

if [[ "$FAIL" -eq 0 ]]; then ok "no-jq-production-surfaces"; fi
exit "$FAIL"
"""
src = _src.replace("#!/usr/bin/env bash", "").replace("set -euo pipefail", "")
src = re.sub(r'ROOT="[^"]*"', 'ROOT="' + str(ROOT) + '"', src, count=1)
src = src.replace('.sh"', '.py"').replace('bash "', 'python3 "')
rc = subprocess.run(["bash", "-c", src], cwd=str(ROOT), env=env, shell=False).returncode
if rc == 0:
    print("OK  no-jq-guard")
raise SystemExit(rc or 0)
