#!/usr/bin/env python3
import os, re, subprocess, sys
from pathlib import Path
ROOT = Path(__file__).resolve().parent.parent.parent
env = os.environ.copy(); env["ROOT"]=str(ROOT); env["PYTHONPATH"]=str(ROOT/"scripts")
_src = """#!/usr/bin/env bash
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
TREES=(core/commands core/skills core/rules core/providers docs/guides)
PATTERNS=(
  '`gh '
  'gh pr '
  'gh api '
  'gh auth'
  '`curl'
  ' curl '
  '`jq'
  ' jq '
  '`rsync'
  'bash scripts/host'
  'host.sh'
  'host_transport.sh'
)
FAIL=0
for tree in "${TREES[@]}"; do
  [ -d "$ROOT/$tree" ] || continue
  while IFS= read -r f; do
    for pat in "${PATTERNS[@]}"; do
      if grep -Fq "$pat" "$f" 2>/dev/null; then
        echo "FAIL banned literal '$pat' in $f"
        FAIL=1
      fi
    done
  done < <(find "$ROOT/$tree" -type f \( -name '*.md' -o -name '*.mdc' -o -name '*.json' \) ! -path '*/prds/*')
done
[ "$FAIL" -eq 0 ] || exit 1
echo "OK  prose-config-closure"
"""
src = _src.replace("#!/usr/bin/env bash", "").replace("set -euo pipefail", "")
src = re.sub(r'ROOT="[^"]*"', 'ROOT="' + str(ROOT) + '"', src, count=1)
src = src.replace('.sh"', '.py"').replace('bash "', 'python3 "')
rc = subprocess.run(["bash", "-c", src], cwd=str(ROOT), env=env, shell=False).returncode
if rc == 0:
    print("OK  prose-config-closure")
raise SystemExit(rc or 0)
