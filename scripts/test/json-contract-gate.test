#!/usr/bin/env python3
"""JSON contract parity for ported check-gate.py (PRD 042 R7) — native Python."""
from __future__ import annotations

import json
import os
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent.parent
GATE_PY = ROOT / "scripts" / "check-gate.py"

CASES = (
    ("green", "green", 0, "green"),
    ("yellow-pending", "yellow-pending", 10, "yellow"),
    ("red-fail", "red-fail", 20, "red"),
    ("advisory-fail", "advisory-fail", 0, "green"),
    ("blocked-empty", "blocked-empty", 30, "blocked"),
)


def run_case(name: str, fixture: str, expect_ec: int, expect_verdict: str) -> int:
    env = os.environ.copy()
    env["PYTHONPATH"] = str(ROOT / "scripts")
    env["GITHUB_TOKEN"] = "gh_fixture_token_for_tests"
    env["SW_GATE_FIXTURE"] = fixture
    env["SW_HOST_FIXTURE"] = fixture
    env["SW_GATE_NOW"] = "1577838000"
    completed = subprocess.run(
        [sys.executable, str(GATE_PY), "42"],
        cwd=str(ROOT),
        env=env,
        capture_output=True,
        text=True,
    )
    try:
        payload = json.loads(completed.stdout or "{}")
    except json.JSONDecodeError:
        payload = {}
    verdict = payload.get("verdict", "")
    if completed.returncode != expect_ec or verdict != expect_verdict:
        print(
            f"FAIL {name} expected exit={expect_ec} verdict={expect_verdict} "
            f"got exit={completed.returncode} verdict={verdict}"
        )
        if completed.stdout:
            print(completed.stdout)
        return 1
    if "verdict" not in payload or "reason" not in payload:
        print(f"FAIL {name}: missing verdict/reason keys")
        return 1
    print(f"OK  {name} exit={completed.returncode} verdict={verdict}")
    return 0


def main() -> int:
    fail = 0
    for case in CASES:
        fail |= run_case(*case)
    return fail


if __name__ == "__main__":
    raise SystemExit(main())
