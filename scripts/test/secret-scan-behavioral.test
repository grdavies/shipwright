#!/usr/bin/env python3
import os, re, subprocess, sys
from pathlib import Path
ROOT = Path(__file__).resolve().parent.parent.parent
env = os.environ.copy(); env["ROOT"]=str(ROOT); env["PYTHONPATH"]=str(ROOT/"scripts")
_src = """#!/usr/bin/env bash
set -euo pipefail
ROOT="/Volumes/External Storage/GitHub/shipwright/.sw-worktrees/cross-platform-python-standardization-phase-hooks-security-filters-providers-l"
SCAN="$ROOT/scripts/secret-scan.py"
GUARD="$ROOT/scripts/redaction-guard.py"
PUSH="$ROOT/scripts/git-push.sh"
FAIL=0
ok() { echo "OK  $1"; }
bad() { echo "FAIL $1"; FAIL=1; }
FIX=$(mktemp -d)
trap 'rm -rf "$FIX"' EXIT
cd "$FIX"
git init -q
git config user.email test@test.com
git config user.name Test
git commit --allow-empty -q -m init
mkdir -p .cursor
cp "$ROOT/.cursor/sw-secret-scan-allowlist.json" .cursor/ 2>/dev/null || echo '{"lines":[],"paths":[]}' > .cursor/sw-secret-scan-allowlist.json
echo 'api_key=ghp_deadbeefdeadbeefdeadbeefdeadbeefdead' > leak.txt
git add leak.txt && git commit -q -m 'plant secret'
set +e
python3 "$SCAN" pre-push >/dev/null 2>&1
EC=$?
set -e
[ "$EC" -eq 1 ] && ok secret-scan-deny || bad "secret-scan-deny expected 1 got $EC"
git reset --hard -q HEAD~1 2>/dev/null || true
echo 'SECRET_SCAN_FIXTURE_ALLOWLIST_MARKER sk_test_fixture_allowlisted_secret_scan_0123456789' > fixture.txt
git add fixture.txt && git commit -q -m allowlisted
set +e
python3 "$SCAN" pre-push >/dev/null 2>&1
EC_ALLOW=$?
set -e
[ "$EC_ALLOW" -eq 0 ] && ok secret-scan-allowlist || bad "allowlist expected 0 got $EC_ALLOW"
echo 'not-json' > .cursor/sw-secret-scan-allowlist.json
set +e
python3 "$SCAN" pre-push >/dev/null 2>&1
EC_CORRUPT=$?
set -e
[ "$EC_CORRUPT" -eq 2 ] && ok secret-scan-corrupt-allowlist || bad "corrupt allowlist expected 2 got $EC_CORRUPT"
grep -q 'secret-scan.py' "$PUSH" && ok git-push-chain || bad git-push-chain
set +e
python3 "$GUARD" check-command -- git filter-branch --force --index-filter 'true' HEAD >/dev/null 2>&1
EC_FB=$?
python3 "$GUARD" check-command -- git filter-branch --force main..feature-branch >/dev/null 2>&1
EC_RANGE=$?
set -e
[ "$EC_FB" -eq 20 ] && ok redaction-guard-bare || bad "bare filter-branch expected 20 got $EC_FB"
[ "$EC_RANGE" -eq 0 ] && ok redaction-guard-range || bad "range filter-branch expected 0 got $EC_RANGE"
SAMPLE='token=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx'
RED=$(printf '%s' "$SAMPLE" | python3 "$ROOT/scripts/memory-redact.py")
echo "$RED" | grep -q 'ghp_' && bad memory-redact || ok memory-redact
[ "$FAIL" -eq 0 ] || exit 1
echo "OK  secret-scan-behavioral"
"""
src = _src.replace("#!/usr/bin/env bash", "").replace("set -euo pipefail", "")
src = re.sub(r'ROOT="[^"]*"', 'ROOT="' + str(ROOT) + '"', src, count=1)
src = src.replace('.sh"', '.py"').replace('bash "', 'python3 "')
rc = subprocess.run(["bash", "-c", src], cwd=str(ROOT), env=env, shell=False).returncode
if rc == 0:
    print("OK  secret-scan-behavioral")
raise SystemExit(rc or 0)
