{
  "$schema": "../docs/config.schema.json",
  "defaultBaseBranch": "main",
  "stateFile": ".git/phase-flow.json",
  "agentsFile": "AGENTS.md",
  "prdsDir": "prds",
  "tasksDir": "prds",
  "verify": {
    "lint": "echo 'configure verify.lint for your repo'",
    "typecheck": "echo 'configure verify.typecheck for your repo'",
    "test": "echo 'configure verify.test for your repo'"
  },
  "review": {
    "provider": "coderabbit"
  },
  "coderabbit": {
    "noDefer": true,
    "reviewGraceMinutes": 15
  },
  "checks": {
    "policy": "all",
    "treatNeutralAsPass": true,
    "neutralAllowlist": [],
    "watch": {
      "maxWaitMinutes": 20,
      "pollSeconds": 45
    }
  },
  "worktree": {
    "parallelCeiling": 4,
    "scaffold": {
      "portRangeStart": 9100,
      "portRangeEnd": 9199,
      "dbStrategy": "schema-prefix",
      "dbTemplate": ""
    }
  },
  "memory": {
    "provider": "recallium",
    "project": "my-project",
    "defaultScope": "project",
    "connection": {
      "restBaseUrl": "http://localhost:8001"
    },
    "autoSync": {
      "enabled": true,
      "minTurns": 10,
      "minMinutes": 120
    },
    "guardrails": {
      "enforceBeforeSubmit": true,
      "requireRuleClass": false
    }
  }
}
