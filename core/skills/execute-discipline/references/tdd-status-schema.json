{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "tdd-gate status",
  "type": "object",
  "required": ["taskRef"],
  "properties": {
    "rid": { "type": "string" },
    "taskRef": { "type": "string" },
    "testScenario": { "type": "string" },
    "red": {
      "type": "object",
      "properties": {
        "observed": { "type": "boolean" },
        "exitCode": { "type": "integer" }
      }
    },
    "green": {
      "type": "object",
      "properties": {
        "observed": { "type": "boolean" },
        "exitCode": { "type": "integer" }
      }
    },
    "testWeakened": { "type": "boolean" },
    "skipped": { "type": "boolean" },
    "skipReason": { "type": "string" }
  }
}
