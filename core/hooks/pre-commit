#!/usr/bin/env bash
set -euo pipefail
DIR="$(cd "$(dirname "$0")" && pwd)"
[ -x "$DIR/pre-commit-frozen.sh" ] && "$DIR/pre-commit-frozen.sh"
[ -x "$DIR/pre-commit-completed-unit.sh" ] && "$DIR/pre-commit-completed-unit.sh"
GUARD="$DIR/../../scripts/index-region-guard.sh"
[ -x "$GUARD" ] && "$GUARD" --staged
PRIV="$DIR/../../scripts/planning-privacy-guard.sh"
[ -x "$PRIV" ] && "$PRIV" --staged
