{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "shipwright-loop-health",
  "description": "Downstream-cost loop-health diagnostic record (PRD 041 R29). Read-only; not an optimization target.",
  "type": "object",
  "required": ["version", "recordedAt", "diagnosticOnly", "gating", "metrics"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "recordedAt": { "type": "string", "minLength": 1 },
    "diagnosticOnly": { "type": "boolean", "const": true },
    "gating": { "type": "boolean", "const": false },
    "metrics": { "$ref": "#/definitions/metrics" }
  },
  "definitions": {
    "metrics": {
      "type": "object",
      "required": ["reviewEffort", "reworkDefect", "incidents", "inboxRanking"],
      "additionalProperties": false,
      "properties": {
        "reviewEffort": {
          "type": "object",
          "required": ["reviewRounds", "stabilizeReentries"],
          "additionalProperties": false,
          "properties": {
            "reviewRounds": { "type": "integer", "minimum": 0 },
            "stabilizeReentries": { "type": "integer", "minimum": 0 }
          }
        },
        "reworkDefect": {
          "type": "object",
          "required": ["reopenedPhases", "postMergeReverts"],
          "additionalProperties": false,
          "properties": {
            "reopenedPhases": { "type": "integer", "minimum": 0 },
            "postMergeReverts": { "type": "integer", "minimum": 0 }
          }
        },
        "incidents": {
          "type": "object",
          "required": ["status"],
          "additionalProperties": false,
          "properties": {
            "status": { "type": "string", "enum": ["known", "unknown"] },
            "count": { "type": "integer", "minimum": 0 },
            "source": { "type": "string" },
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id"],
                "properties": {
                  "id": { "type": "string" },
                  "kind": { "type": "string" }
                },
                "additionalProperties": true
              }
            }
          }
        },
        "inboxRanking": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["signalId", "score", "recurrence", "reviewRounds"],
            "additionalProperties": false,
            "properties": {
              "signalId": { "type": "string", "minLength": 1 },
              "title": { "type": "string" },
              "score": { "type": "number", "minimum": 0 },
              "recurrence": { "type": "integer", "minimum": 0 },
              "reviewRounds": { "type": "integer", "minimum": 0 },
              "capturedAt": { "type": "string" },
              "stale": { "type": "boolean" }
            }
          }
        }
      }
    }
  }
}
