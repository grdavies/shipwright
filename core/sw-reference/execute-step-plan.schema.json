{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/grdavies/shipwright/core/sw-reference/execute-step-plan.schema.json",
  "title": "Shipwright execute-step-plan artifact",
  "description": "Validated per-ref execute DAG for phase-mode /sw-ship fan-out (PRD 053).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "tier",
    "phaseId",
    "phaseSlug",
    "refs",
    "edges",
    "batches",
    "planPolicy",
    "kernelVersion",
    "guidelineVersion",
    "validatedAt"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "tier": {
      "type": "string",
      "const": "execute"
    },
    "phaseId": {
      "type": "string",
      "minLength": 1
    },
    "phaseSlug": {
      "type": "string",
      "minLength": 1
    },
    "refs": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ref"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/edge"
      }
    },
    "batches": {
      "type": "array",
      "items": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "minItems": 1
      }
    },
    "planPolicy": {
      "type": "string",
      "enum": [
        "canonical",
        "proposed"
      ]
    },
    "kernelVersion": {
      "type": "string"
    },
    "guidelineVersion": {
      "type": "string"
    },
    "validatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "definitions": {
    "ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "branch",
        "files",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^\\d+(\\.\\d+)+$"
        },
        "branch": {
          "type": "string",
          "minLength": 1
        },
        "files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "in-flight",
            "green",
            "blocked",
            "skipped"
          ]
        },
        "parentRef": {
          "type": "string",
          "pattern": "^\\d+(\\.\\d+)+$"
        }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from",
        "to"
      ],
      "properties": {
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        }
      }
    }
  }
}
