{
  "$schema": "config.schema.json",
  "defaultBaseBranch": "main",
  "stateFile": ".git/shipwright.json",
  "agentsFile": "AGENTS.md",
  "prdsDir": "docs/prds",
  "decisionsDir": "docs/decisions",
  "tasksDir": "docs/prds",
  "doc": {
    "afterTasks": "confirm"
  },
  "deliver": {
    "phaseAckCadence": 0,
    "autonomy": {
      "mode": "autonomous",
      "maxRunMinutes": 1440,
      "maxIterations": 500
    },
    "remediation": {
      "maxAttempts": 2
    },
    "watchdog": {
      "phaseTimeoutMinutes": 240
    }
  },
  "verify": {
    "lint": "echo 'configure verify.lint for your repo'",
    "typecheck": "echo 'configure verify.typecheck for your repo'",
    "test": "echo 'configure verify.test for your repo'"
  },
  "verifyE2e": {
    "enabled": false,
    "provider": "none",
    "routes": []
  },
  "review": {
    "provider": "none",
    "local": {
      "enabled": true,
      "provider": "native",
      "apply": "auto",
      "grouping": "auto",
      "ui": {
        "enrich": "off"
      },
      "gate": {
        "surface": ["P0", "P1", "P2", "P3"],
        "haltOn": []
      }
    }
  },
  "coderabbit": {
    "noDefer": true,
    "reviewGraceMinutes": 15
  },
  "checks": {
    "policy": "all",
    "treatNeutralAsPass": true,
    "neutralAllowlist": [],
    "watch": {
      "maxWaitMinutes": 20,
      "pollSeconds": 45
    }
  },
  "worktree": {
    "parallelCeiling": 4,
    "scaffold": {
      "portRangeStart": 9100,
      "portRangeEnd": 9199,
      "dbStrategy": "schema-prefix",
      "dbTemplate": ""
    }
  },
  "models": {
    "tiers": {
      "cheap": "composer-2.5-fast",
      "build": "composer-2.5",
      "mid": "gpt-5.5-medium",
      "deep": "claude-opus-4-8-thinking-high"
    },
    "aliases": {
      "fast": "cheap"
    },
    "roles": {
      "builder": "build",
      "reviewer": "build"
    },
    "routing": {
      "commands": {
        "sw-prd": "deep",
        "sw-execute": "build",
        "sw-triage": "cheap",
        "sw-doc": "inherit"
      },
      "skills": {
        "prd": "deep",
        "triage": "cheap"
      }
    }
  },
  "communication": {
    "defaultIntensity": "full",
    "routing": {
      "commands": {
        "sw-prd": "lite",
        "sw-triage": "ultra",
        "sw-doc-review": "normal",
        "sw-execute": "full"
      },
      "skills": {}
    }
  },
  "invariantsFile": "INVARIANTS.md",
  "memory": {
    "provider": "in-repo",
    "project": "my-project",
    "defaultScope": "project",
    "inRepo": {
      "storeDir": ".cursor/sw-memory",
      "commitMode": "committed"
    },
    "connection": {
      "restBaseUrl": "http://localhost:8001"
    },
    "autoSync": {
      "enabled": true,
      "minTurns": 10,
      "minMinutes": 120
    },
    "guardrails": {
      "enforceBeforeSubmit": true,
      "requireRuleClass": false
    }
  }
}
