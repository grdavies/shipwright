{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/grdavies/shipwright/core/sw-reference/schemas/orchestrator-step-plan.schema.json",
  "title": "Shipwright orchestrator-step-plan artifact",
  "description": "Single-tier closed-world step vocabulary per orchestrator (PRD 024 TR1).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "orchestratorTypes"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "description": {
      "type": "string"
    },
    "orchestratorTypes": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/definitions/orchestratorTypeGuideline"
      }
    }
  },
  "definitions": {
    "stepId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "orderingInvariant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "before",
        "after"
      ],
      "properties": {
        "before": {
          "$ref": "#/definitions/stepId"
        },
        "after": {
          "$ref": "#/definitions/stepId"
        }
      }
    },
    "orchestratorTypeGuideline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidateSteps",
        "requiredSteps",
        "optionalSteps",
        "forbiddenSteps",
        "orderingInvariants",
        "canonicalChain"
      ],
      "properties": {
        "candidateSteps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/stepId"
          },
          "uniqueItems": true
        },
        "requiredSteps": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/stepId"
          },
          "uniqueItems": true
        },
        "optionalSteps": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/stepId"
          },
          "uniqueItems": true
        },
        "forbiddenSteps": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/stepId"
          },
          "uniqueItems": true
        },
        "orderingInvariants": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/orderingInvariant"
          }
        },
        "canonicalChain": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/stepId"
          }
        }
      }
    }
  }
}
