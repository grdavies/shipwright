{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/grdavies/shipwright/core/sw-reference/schemas/orchestrator-guideline-pack.schema.json",
  "title": "Shipwright orchestrator guideline pack",
  "description": "Per-orchestrator canonical fallback chains, signal-conditional floors, and forbidden deliver-only steps (PRD 024 TR2).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "guidelineVersion",
    "orchestratorType",
    "packId",
    "canonicalFallbackChain",
    "candidateSteps",
    "requiredSteps",
    "optionalSteps",
    "forbiddenDeliverOnlySteps",
    "forbiddenDeviations",
    "signalConditionalFloors",
    "floorRuleRefs"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "guidelineVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "description": {
      "type": "string"
    },
    "orchestratorType": {
      "type": "string",
      "enum": ["debug", "doc", "feedback"]
    },
    "packId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "canonicalFallbackChain": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/stepId"
      }
    },
    "candidateSteps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/stepId"
      },
      "uniqueItems": true
    },
    "requiredSteps": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/stepId"
      },
      "uniqueItems": true
    },
    "optionalSteps": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/stepId"
      },
      "uniqueItems": true
    },
    "forbiddenDeliverOnlySteps": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/stepId"
      },
      "uniqueItems": true
    },
    "allowedReorderings": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/reordering"
      }
    },
    "forbiddenDeviations": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/forbiddenDeviation"
      }
    },
    "signalConditionalFloors": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/signalConditionalFloor"
      }
    },
    "floorRuleRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  },
  "definitions": {
    "stepId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "reordering": {
      "type": "object",
      "additionalProperties": false,
      "required": ["steps"],
      "properties": {
        "steps": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/definitions/stepId"
          }
        },
        "anchorBefore": {
          "$ref": "#/definitions/stepId"
        },
        "anchorAfter": {
          "$ref": "#/definitions/stepId"
        }
      }
    },
    "forbiddenDeviation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "reason"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "omitStep": {
          "$ref": "#/definitions/stepId"
        },
        "reorderBefore": {
          "$ref": "#/definitions/stepId"
        },
        "reorderAfter": {
          "$ref": "#/definitions/stepId"
        }
      }
    },
    "signalConditionalFloor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "mandatorySteps", "triggers"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "mandatorySteps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/stepId"
          },
          "uniqueItems": true
        },
        "triggers": {
          "type": "object"
        }
      }
    }
  }
}
