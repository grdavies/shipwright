{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/grdavies/shipwright/core/sw-reference/inflight-signal.schema.json",
  "title": "Planning INDEX inFlight tuple",
  "description": "Committed in-flight signal per unit (PRD 032 R1/R13). Lifecycle in-progress is derived by PRD 033 — never stored here.",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["runId", "branch", "leaseEpoch"],
      "properties": {
        "runId": { "type": "string", "minLength": 1 },
        "branch": { "type": "string", "minLength": 1 },
        "leaseEpoch": { "type": "integer", "minimum": 1 }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["runId", "branchToken", "leaseEpoch"],
      "properties": {
        "runId": { "type": "string", "minLength": 1 },
        "branchToken": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{16}$",
          "description": "Opaque hashed branch suffix — PRD 034 redaction handoff (R13)."
        },
        "leaseEpoch": { "type": "integer", "minimum": 1 }
      }
    }
  ]
}
