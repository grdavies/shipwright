{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "shipwright-root-cause-records",
  "description": "Cross-run escalated root-cause records (PRD 041 R23). Distinct from failure-signature capture.",
  "type": "object",
  "required": ["version", "records"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "records": {
      "type": "array",
      "items": { "$ref": "#/definitions/record" }
    }
  },
  "definitions": {
    "signatureKey": {
      "type": "object",
      "required": ["checkId", "exitCode", "jobId", "messageClass"],
      "properties": {
        "checkId": { "type": "string", "minLength": 1 },
        "exitCode": { "type": "integer" },
        "jobId": { "type": "string", "minLength": 1 },
        "messageClass": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "anomalyAnnotation": {
      "type": "object",
      "required": ["patternId", "matched", "annotation"],
      "properties": {
        "patternId": { "type": "string", "minLength": 1 },
        "matched": { "type": "boolean" },
        "annotation": { "type": "string" },
        "autoAct": { "type": "boolean", "const": false }
      },
      "additionalProperties": false
    },
    "flakeWaiver": {
      "type": "object",
      "required": ["acknowledged"],
      "properties": {
        "acknowledged": { "type": "boolean" },
        "acknowledgedAt": { "type": ["string", "null"] },
        "acknowledgedBy": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "record": {
      "type": "object",
      "required": [
        "id",
        "signatureKey",
        "status",
        "signatureClass",
        "escalatedAt",
        "source",
        "writer",
        "failureText",
        "rca",
        "anomalyPatterns",
        "flakeWaiver",
        "loopClosed"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "signatureKey": { "$ref": "#/definitions/signatureKey" },
        "status": { "type": "string", "enum": ["escalated", "closed"] },
        "signatureClass": { "type": "string", "enum": ["flake", "regression", "infra"] },
        "escalatedAt": { "type": "string" },
        "source": { "type": "string" },
        "writer": { "type": "string" },
        "failureText": { "type": "string" },
        "rca": {
          "type": "object",
          "required": ["entry", "rootCause", "recommendedFix", "verification"],
          "properties": {
            "entry": { "type": "string", "enum": ["debug"] },
            "hypotheses": {
              "type": "array",
              "items": { "type": "string" }
            },
            "rootCause": { "type": "string" },
            "recommendedFix": { "type": "string" },
            "verification": { "type": "string" }
          },
          "additionalProperties": false
        },
        "anomalyPatterns": {
          "type": "array",
          "items": { "$ref": "#/definitions/anomalyAnnotation" }
        },
        "flakeWaiver": { "$ref": "#/definitions/flakeWaiver" },
        "loopClosed": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  }
}
