{
  "version": 1,
  "guidelineVersion": "1.0.0",
  "orchestratorType": "feedback",
  "packId": "feedback",
  "description": "Feedback orchestrator guideline pack \u2014 normalize\u2192redact\u2192route chain with untrusted-signal halts (PRD 024 TR2).",
  "canonicalFallbackChain": [
    "memory-prework",
    "normalize",
    "redact",
    "dedup",
    "route",
    "human-confirm-halt",
    "handoff",
    "record"
  ],
  "candidateSteps": [
    "memory-prework",
    "normalize",
    "redact",
    "dedup",
    "route",
    "hook-trigger-halt",
    "human-confirm-halt",
    "handoff",
    "record"
  ],
  "requiredSteps": [
    "memory-prework",
    "normalize",
    "redact",
    "dedup",
    "route",
    "human-confirm-halt",
    "handoff",
    "record"
  ],
  "optionalSteps": [
    "hook-trigger-halt"
  ],
  "forbiddenDeliverOnlySteps": [
    "merge-enqueue",
    "merge-run-next",
    "terminal-ship",
    "git-push",
    "main-merge",
    "sw-execute",
    "lock-acquire",
    "phase-merge",
    "wave-plan-validate"
  ],
  "allowedReorderings": [],
  "forbiddenDeviations": [
    {
      "id": "skip-redact",
      "reason": "inbound signals must be redacted before any route record (R23)",
      "omitStep": "redact"
    },
    {
      "id": "skip-human-confirm-halt",
      "reason": "routed dispatch requires persisted human-confirm (R19 FB-A1)",
      "omitStep": "human-confirm-halt"
    },
    {
      "id": "handoff-before-human-confirm",
      "reason": "handoff must follow human-confirm-halt",
      "reorderBefore": "handoff",
      "reorderAfter": "human-confirm-halt"
    }
  ],
  "signalConditionalFloors": [
    {
      "id": "feedback-hook-monitor-halt",
      "mandatorySteps": [
        "hook-trigger-halt"
      ],
      "triggers": {
        "type": "signal_context",
        "field": "invocation",
        "equals": [
          "hook",
          "monitor"
        ]
      }
    }
  ],
  "floorRuleRefs": [
    "security-sensitive-paths",
    "kernel-scripts-providers",
    "hooks-manifest"
  ]
}
