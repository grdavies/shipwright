{
  "version": 1,
  "guidelineVersion": "1.0.0",
  "orchestratorType": "debug",
  "packId": "debug",
  "description": "Debug orchestrator guideline pack \u2014 diagnosis vs implement segments (PRD 024 TR2 / PRD 067 R12). Ship/execute forbidden before route confirm.",
  "canonicalFallbackChain": [
    "memory-prework",
    "triage",
    "normalize",
    "enrich",
    "rca",
    "route-confirm-halt",
    "route",
    "rca-human-decision-halt",
    "record"
  ],
  "candidateSteps": [
    "memory-prework",
    "triage",
    "normalize",
    "enrich",
    "rca",
    "route-confirm-halt",
    "route",
    "rca-human-decision-halt",
    "record"
  ],
  "requiredSteps": [
    "memory-prework",
    "triage",
    "normalize",
    "rca",
    "route-confirm-halt",
    "route",
    "rca-human-decision-halt",
    "record"
  ],
  "optionalSteps": [
    "enrich"
  ],
  "forbiddenDeliverOnlySteps": [
    "git-push",
    "lock-acquire",
    "main-merge",
    "merge-enqueue",
    "merge-run-next",
    "phase-merge",
    "sw-commit",
    "sw-execute",
    "sw-pr",
    "sw-ship",
    "sw-watch-ci",
    "terminal-ship",
    "wave-plan-validate"
  ],
  "allowedReorderings": [],
  "forbiddenDeviations": [
    {
      "id": "skip-route-confirm-halt",
      "reason": "route confirmation must fire before in-turn continuation (R19 DBG-A1)",
      "omitStep": "route-confirm-halt"
    },
    {
      "id": "skip-rca-human-decision-halt",
      "reason": "RCA human-decision halt is driver-asserted (R19)",
      "omitStep": "rca-human-decision-halt"
    },
    {
      "id": "route-before-confirm",
      "reason": "route must follow route-confirm-halt",
      "reorderBefore": "route",
      "reorderAfter": "route-confirm-halt"
    },
    {
      "id": "execute-before-route-confirm",
      "reason": "execute/ship forbidden before route confirm (PRD 067 R12)",
      "omitStep": null,
      "forbiddenBefore": "route-confirm-halt",
      "forbiddenSteps": [
        "sw-execute",
        "sw-ship"
      ]
    }
  ],
  "signalConditionalFloors": [
    {
      "id": "debug-sentry-enrich",
      "mandatorySteps": [
        "enrich"
      ],
      "triggers": {
        "type": "signal_context",
        "field": "signal_type",
        "equals": [
          "sentry",
          "crash",
          "error"
        ]
      }
    }
  ],
  "floorRuleRefs": [
    "security-sensitive-paths",
    "kernel-scripts-providers",
    "hooks-manifest"
  ],
  "segments": {
    "diagnosis": {
      "steps": [
        "memory-prework",
        "triage",
        "normalize",
        "enrich",
        "rca",
        "route-confirm-halt",
        "route",
        "rca-human-decision-halt",
        "record"
      ],
      "forbiddenSteps": [
        "sw-execute",
        "sw-ship",
        "sw-commit",
        "sw-pr",
        "sw-watch-ci",
        "merge-enqueue",
        "merge-run-next",
        "terminal-ship",
        "main-merge"
      ]
    },
    "implementHandoff": {
      "steps": [
        "materialize-debug-pack",
        "print-deliver-run",
        "confirm-handoff"
      ],
      "allowedAfterConfirm": [
        "sw-deliver-run"
      ],
      "forbidden": [
        "task-spawn-deliver",
        "nested-deliver-loop"
      ]
    }
  }
}
