{
  "version": 1,
  "guidelineVersion": "1.0.0",
  "orchestratorType": "doc",
  "packId": "doc",
  "description": "Doc orchestrator guideline pack \u2014 tier-gated atomic chain with doc-review and afterTasks halts (PRD 024 TR2).",
  "canonicalFallbackChain": [
    "memory-prework",
    "sw-triage",
    "sw-brainstorm",
    "sw-prd",
    "sw-doc-review",
    "doc-review-halt-gated-auto",
    "spec-rigor",
    "sw-freeze",
    "sw-tasks",
    "afterTasks-checkpoint"
  ],
  "candidateSteps": [
    "memory-prework",
    "sw-triage",
    "sw-brainstorm",
    "sw-prd",
    "sw-doc-review",
    "spec-rigor",
    "sw-freeze",
    "sw-tasks",
    "doc-review-halt-manual",
    "doc-review-halt-gated-auto",
    "afterTasks-checkpoint"
  ],
  "requiredSteps": [
    "memory-prework",
    "sw-triage",
    "sw-prd",
    "sw-doc-review",
    "spec-rigor",
    "sw-freeze",
    "sw-tasks",
    "afterTasks-checkpoint"
  ],
  "optionalSteps": [
    "sw-brainstorm",
    "doc-review-halt-manual",
    "doc-review-halt-gated-auto"
  ],
  "forbiddenDeliverOnlySteps": [
    "merge-enqueue",
    "merge-run-next",
    "terminal-ship",
    "git-push",
    "main-merge",
    "sw-execute",
    "lock-acquire",
    "phase-merge",
    "wave-plan-validate"
  ],
  "allowedReorderings": [],
  "forbiddenDeviations": [
    {
      "id": "skip-doc-review",
      "reason": "sw-doc-review is mandatory before freeze",
      "omitStep": "sw-doc-review"
    },
    {
      "id": "skip-afterTasks-checkpoint",
      "reason": "doc.afterTasks checkpoint boundary must be preserved (R19 DOC-A1)",
      "omitStep": "afterTasks-checkpoint"
    },
    {
      "id": "freeze-before-doc-review-halt",
      "reason": "doc-review halts must fire before freeze steps",
      "reorderBefore": "sw-freeze",
      "reorderAfter": "doc-review-halt-manual"
    },
    {
      "id": "freeze-before-gated-auto-halt",
      "reason": "doc-review halts must fire before freeze steps",
      "reorderBefore": "sw-freeze",
      "reorderAfter": "doc-review-halt-gated-auto"
    }
  ],
  "signalConditionalFloors": [
    {
      "id": "doc-tier-brainstorm",
      "mandatorySteps": [
        "sw-brainstorm"
      ],
      "triggers": {
        "type": "signal_context",
        "field": "tier",
        "equals": [
          "large",
          "epic"
        ]
      }
    },
    {
      "id": "doc-review-manual-halt",
      "mandatorySteps": [
        "doc-review-halt-manual"
      ],
      "triggers": {
        "type": "signal_context",
        "field": "doc_review_mode",
        "equals": [
          "manual"
        ]
      }
    },
    {
      "id": "doc-review-gated-auto-halt",
      "mandatorySteps": [
        "doc-review-halt-gated-auto"
      ],
      "triggers": {
        "type": "signal_context",
        "field": "doc_review_mode",
        "equals": [
          "gated_auto"
        ]
      }
    }
  ],
  "floorRuleRefs": [
    "security-sensitive-paths",
    "kernel-scripts-providers",
    "hooks-manifest"
  ]
}
