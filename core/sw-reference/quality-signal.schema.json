{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "quality-signal.schema.json",
  "title": "Quality harness refactor-worthiness signal",
  "type": "object",
  "additionalProperties": false,
  "required": ["verdict", "provider"],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["none", "clean", "advise", "poor"],
      "description": "none = provider inactive (quality:none); clean/advise/poor = active harness verdict."
    },
    "provider": {
      "type": "string",
      "description": "Adapter id that produced this signal."
    },
    "skipped": {
      "type": "boolean",
      "description": "True when the adapter intentionally produced a no-op outcome."
    },
    "reason": {
      "type": "string",
      "description": "Human-readable skip or inactive reason."
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "coupling": { "$ref": "#/$defs/metricValue" },
        "cohesion": { "$ref": "#/$defs/metricValue" },
        "complexity": { "$ref": "#/$defs/metricValue" },
        "churn": { "$ref": "#/$defs/metricValue" }
      }
    },
    "metricDelta": {
      "type": "object",
      "additionalProperties": false,
      "description": "Delta vs pre-green snapshot (not absolute values).",
      "properties": {
        "coupling": { "$ref": "#/$defs/metricValue" },
        "cohesion": { "$ref": "#/$defs/metricValue" },
        "complexity": { "$ref": "#/$defs/metricValue" },
        "churn": { "$ref": "#/$defs/metricValue" }
      }
    },
    "perFile": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path"],
        "properties": {
          "path": { "type": "string" },
          "verdict": { "type": "string", "enum": ["clean", "advise", "poor"] },
          "hints": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "refactorHints": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "metricValue": {
      "oneOf": [
        { "type": "number" },
        { "type": "string", "const": "unavailable" }
      ]
    }
  }
}
